---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const successUrl = `${base}thank-you/`;
---

<BaseLayout
  title="Level 303 — Temporary placeholder"
  description="Temporary placeholder while we investigate a site removal by Google. Check back soon."
  ogTitle="Level 303 — Temporary placeholder"
  ogDescription="Temporary placeholder while we investigate a site removal by Google. Check back soon."
>
  <main class="placeholder-page" role="main" aria-labelledby="placeholderHeading">
    <section class="placeholder-card" role="region" aria-labelledby="placeholderHeading">
      <h1 id="placeholderHeading">Level 303 — We'll be back soon</h1>
      <p class="description">We're investigating a site removal by Google. We'll restore service as soon as possible.</p>
      <p class="note">If you need urgent help, reply to the site owner via email.</p>

      <form
        id="contactForm"
        class="contact-form"
        method="post"
        action="/__forms/contact"
        data-success-url={successUrl}
        novalidate
        role="region"
        aria-labelledby="contactHeading"
      >
        <h2 id="contactHeading">Contact</h2>

        <div class="form-group">
          <label for="name">Name <span aria-label="required">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            required
            aria-required="true"
            aria-describedby="nameError"
            autocomplete="name"
          />
          <span id="nameError" class="error-message"></span>
        </div>

        <div class="form-group">
          <label for="email">Email <span aria-label="required">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            required
            aria-required="true"
            aria-describedby="emailError"
            autocomplete="email"
          />
          <span id="emailError" class="error-message"></span>
        </div>

        <div class="form-group">
          <label for="message">Message <span aria-label="required">*</span></label>
          <textarea
            id="message"
            name="message"
            rows="6"
            required
            aria-required="true"
            aria-describedby="messageError"
          ></textarea>
          <span id="messageError" class="error-message"></span>
        </div>

        <input type="text" name="_hp" style="display:none" autocomplete="off" tabindex="-1" />

        <button type="submit" id="submitBtn" class="submit-button" aria-busy="false">Submit</button>
      </form>

      <div id="responseMessage" role="alert" aria-live="polite"></div>
    </section>
  </main>
</BaseLayout>
