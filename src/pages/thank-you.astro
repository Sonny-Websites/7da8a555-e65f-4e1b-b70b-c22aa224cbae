---
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Level 303 — Message received"
  description="Your message has been received."
  ogTitle="Level 303 — Message received"
  ogDescription="Your message has been received."
>
  <main class="placeholder-page" role="main" aria-labelledby="thankHeading">
    <section class="placeholder-card" role="region" aria-labelledby="thankHeading">
      <h1 id="thankHeading">Thanks, your message was received.</h1>
      <p class="description">We will review it and respond as soon as possible.</p>
      <a href={`${base}`} class="submit-button" style="display:inline-flex;padding:10px 20px;text-decoration:none;">Back to placeholder page</a>
    </section>
  </main>
</BaseLayout>
